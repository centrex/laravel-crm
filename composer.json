{
    "name": "centrex/laravel-crm",
    "description": "Core CRM package for companies, contacts, leads, deals, and activities",
    "keywords": [
        "centrex",
        "laravel",
        "laravel-crm"
    ],
    "homepage": "https://github.com/centrex/laravel-crm",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "rochi88",
            "email": "raisul.me@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.5",
        "larastan/larastan": "^2.0",
        "orchestra/testbench": "^9.5",
        "pestphp/pest": "^3.4",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^1.0",
        "phpstan/phpstan-phpunit": "^1.0",
        "rector/rector": "^1.2",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Centrex\\Crm\\": "src/",
            "Centrex\\Crm\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Centrex\\Crm\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-crm --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "@php vendor/phpstan/phpstan/phpstan analyse",
        "test-coverage": "@php vendor/pestphp/pest/bin/pest --coverage",
        "refacto": "@php vendor/rector/rector/bin/rector",
        "lint": "@php vendor/laravel/pint/builds/pint",
        "test:refacto": "@php vendor/rector/rector/bin/rector --dry-run",
        "test:lint": "@php vendor/laravel/pint/builds/pint --test",
        "test:types": "@php vendor/phpstan/phpstan/phpstan analyse",
        "test:unit": "@php vendor/pestphp/pest/bin/pest -p",
        "test": [
            "@test:refacto",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Centrex\\Crm\\CrmServiceProvider"
            ],
            "aliases": {
                "Crm": "Centrex\\Crm\\Facades\\Crm"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
